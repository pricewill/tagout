// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SpeciesType {
  FISH
  BIG_GAME
  BIRD
  OTHER
}

model User {
  id           String    @id @default(cuid())
  username     String    @unique
  display_name String
  avatar_url   String?
  bio          String?
  home_state   String?
  created_at   DateTime  @default(now())

  harvests  Harvest[]
  likes     Like[]
  comments  Comment[]
  followers Follow[]  @relation("following")
  following Follow[]  @relation("follower")
}

model Harvest {
  id                String      @id @default(cuid())
  user_id           String
  species           String
  species_type      SpeciesType
  method            String
  weight_lbs        Float?
  length_in         Float?
  caption           String?
  ai_id_result      String?
  ai_id_confidence  Float?
  harvested_at      DateTime
  created_at        DateTime    @default(now())

  // General fields
  companions        String?
  state             String?
  land_type         String?     // PUBLIC | PRIVATE | UNKNOWN
  weather           String?     // SUNNY | OVERCAST | WIND | RAIN | SNOW
  moon_phase        String?     // NEW | WAXING_CRESCENT | FIRST_QUARTER | WAXING_GIBBOUS | FULL | WANING_GIBBOUS | LAST_QUARTER | WANING_CRESCENT
  time_of_day       String?     // MORNING | MIDDAY | EVENING | NIGHT
  personal_best     Boolean?    @default(false)
  harvest_success   Boolean?    @default(true)
  video_url         String?

  // Hunting-specific (BIG_GAME | BIRD)
  shot_distance_yards Float?
  season_type       String?     // ARCHERY | MUZZLELOADER | RIFLE | GENERAL | SHOTGUN
  tag_type          String?     // GENERAL | LIMITED_ENTRY | OTC | PRIVATE
  animal_age        String?     // MATURE | YOUNG | UNKNOWN
  point_count       Int?
  score             Float?

  // Fishing-specific (FISH)
  fly_pattern       String?
  water_type        String?     // RIVER | LAKE | RESERVOIR | STREAM | POND | BAY_ESTUARY | OCEAN_OFFSHORE | OCEAN_FLATS
  technique         String?     // DRY_FLY | NYMPH | STREAMER | SPIN | BAITCAST | TROLLING | ICE_FISHING | FLY
  catch_release     Boolean?    @default(false)
  fish_count        Int?
  water_conditions  String?     // CLEAR | MURKY | HIGH | LOW

  user    User           @relation(fields: [user_id], references: [id])
  images  HarvestImage[]
  likes   Like[]
  comments Comment[]
}

model HarvestImage {
  id            String  @id @default(cuid())
  harvest_id    String
  storage_key   String
  url           String
  display_order Int
  is_primary    Boolean @default(false)

  harvest Harvest @relation(fields: [harvest_id], references: [id])
}

model Follow {
  id           String   @id @default(cuid())
  follower_id  String
  following_id String
  created_at   DateTime @default(now())

  follower  User @relation("follower", fields: [follower_id], references: [id])
  following User @relation("following", fields: [following_id], references: [id])

  @@unique([follower_id, following_id])
}

model Like {
  id         String   @id @default(cuid())
  user_id    String
  harvest_id String
  created_at DateTime @default(now())

  user    User    @relation(fields: [user_id], references: [id])
  harvest Harvest @relation(fields: [harvest_id], references: [id])

  @@unique([user_id, harvest_id])
}

model Comment {
  id         String   @id @default(cuid())
  user_id    String
  harvest_id String
  body       String
  created_at DateTime @default(now())

  user    User    @relation(fields: [user_id], references: [id])
  harvest Harvest @relation(fields: [harvest_id], references: [id])
}

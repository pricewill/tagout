generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

enum SpeciesType {
  FISH
  BIG_GAME
  BIRD
  OTHER
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  display_name String
  avatar_url   String?
  bio          String?
  home_state   String?
  created_at   DateTime @default(now())

  harvests  Harvest[]
  likes     Like[]
  comments  Comment[]
  followers Follow[]  @relation("following")
  following Follow[]  @relation("follower")

  @@map("users")
}

model Harvest {
  id               String      @id @default(uuid())
  user_id          String
  species          String
  species_type     SpeciesType
  method           String
  location_label   String
  lat              Float?
  lng              Float?
  weight_lbs       Float?
  length_in        Float?
  caption          String?
  ai_id_result     String?
  ai_id_confidence Float?
  harvested_at     DateTime
  created_at       DateTime    @default(now())

  user     User           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  images   HarvestImage[]
  likes    Like[]
  comments Comment[]

  @@map("harvests")
}

model HarvestImage {
  id            String  @id @default(uuid())
  harvest_id    String
  storage_key   String
  url           String
  display_order Int     @default(0)
  is_primary    Boolean @default(false)

  harvest Harvest @relation(fields: [harvest_id], references: [id], onDelete: Cascade)

  @@map("harvest_images")
}

model Follow {
  id           String   @id @default(uuid())
  follower_id  String
  following_id String
  created_at   DateTime @default(now())

  follower  User @relation("follower", fields: [follower_id], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [following_id], references: [id], onDelete: Cascade)

  @@unique([follower_id, following_id])
  @@map("follows")
}

model Like {
  id         String   @id @default(uuid())
  user_id    String
  harvest_id String
  created_at DateTime @default(now())

  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  harvest Harvest @relation(fields: [harvest_id], references: [id], onDelete: Cascade)

  @@unique([user_id, harvest_id])
  @@map("likes")
}

model Comment {
  id         String   @id @default(uuid())
  user_id    String
  harvest_id String
  body       String
  created_at DateTime @default(now())

  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  harvest Harvest @relation(fields: [harvest_id], references: [id], onDelete: Cascade)

  @@map("comments")
}
